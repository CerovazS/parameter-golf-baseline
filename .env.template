# Relative paths assume commands are run from the repository root.
DATA_PATH=./data/datasets/fineweb10B_sp1024
TOKENIZER_PATH=./data/tokenizers/fineweb_1024_bpe.model

# Baseline training defaults
RUN_ID=baseline_sp1024
VOCAB_SIZE=1024
MAX_WALLCLOCK_SECONDS=600
VAL_LOSS_EVERY=200

# Prefer a uv-managed Python on Leonardo compute nodes so Triton/Inductor can
# find Python headers during runtime compilation.
UV_PYTHON=$HOME/.local/bin/python3.11
UV_LINK_MODE=copy

# Leonardo / SLURM helper
PROXY_PORT=3133

# Optional: set for higher HF Hub rate limits when downloading data.
# HF_TOKEN=
